# ─── LLM ──────────────────────────────────────────────────────────────────────
# Model name — any LiteLLM-supported model (https://docs.litellm.ai/docs/providers)
# Use "openhands/<model>" for OpenHands Cloud, e.g. openhands/claude-sonnet-4-5-20250929
LLM_MODEL=anthropic/claude-sonnet-4-5-20250929

# API key for the LLM provider
LLM_API_KEY=your-llm-api-key

# Optional custom base URL (e.g. for local Ollama or Azure OpenAI)
# LLM_BASE_URL=

# ─── Platform ─────────────────────────────────────────────────────────────────
# One of: paca | jira | trello | clickup | redmine
PLATFORM=paca

# Base URL of your platform instance
# Jira:    https://your-org.atlassian.net
# Trello:  https://api.trello.com
# ClickUp: https://api.clickup.com
# Redmine: https://redmine.example.com
# Paca:    https://api.paca.dev
PLATFORM_BASE_URL=https://api.paca.dev

# API key / token for authentication
PLATFORM_API_KEY=your-platform-api-key

# Email address linked to your platform account (required for Jira, ClickUp)
# PLATFORM_EMAIL=you@example.com

# Username (required for Redmine, Paca)
# PLATFORM_USERNAME=your-username

# The user ID (or username) of the AI account to watch for new task assignments
AI_ACCOUNT_ID=ai-bot

# Optional: platform user ID to assign tasks to for review after a PR is opened
# REVIEWER_ID=reviewer-user-id

# ─── Listening Mode ───────────────────────────────────────────────────────────
# "pull"  — poll the platform API every PULL_INTERVAL seconds
# "push"  — start a FastAPI webhook server; configure your platform to POST to it
LISTEN_MODE=pull

# Polling interval in seconds (only used in pull mode)
PULL_INTERVAL=300

# Webhook server binding (only used in push mode)
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8000

# Optional HMAC secret to validate incoming webhook payloads
# WEBHOOK_SECRET=your-webhook-secret

# ─── GitHub ───────────────────────────────────────────────────────────────────
# Personal access token with `repo` and `pull_request` scopes
GITHUB_TOKEN=your-github-token

# Target repository in owner/repo format
GITHUB_REPO=your-org/your-repo

# Base branch for pull requests
GITHUB_DEFAULT_BRANCH=main

# Git author identity used when the agent makes commits (defaults shown below)
# GITHUB_COMMITTER_NAME=paca-agent
# GITHUB_COMMITTER_EMAIL=paca-agent@users.noreply.github.com

# ─── Docker Sandbox ───────────────────────────────────────────────────────────
# Base image used for the sandboxed execution environment
DOCKER_IMAGE=ubuntu:22.04

# Resource limits for the sandbox container
DOCKER_MEMORY=4g
DOCKER_CPU_COUNT=2
